<?xml version="1.0"?>
<ruleset name="Rishe ERP">
    <description>PSR-12 coding standards for the Rishe ERP plugin.</description>
    <file>rishe.php</file>
    <file>src</file>
    <file>tests</file>
    <exclude-pattern>vendor/*</exclude-pattern>
    <arg name="basepath" value="."/>
    <arg name="colors"/>
    <arg value="sp"/>
    <rule ref="PSR12">
        <exclude name="Generic.Files.LineLength.TooLong"/>
    </rule>
</ruleset>
